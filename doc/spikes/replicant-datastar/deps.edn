{:paths ["src" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}

        ;; Web server — Datastar's http-kit adapter needs >= 2.9.0-beta2 for SSE.
        ;; NOTE: the real app pins http-kit 2.8.0, which the adapter docs say does
        ;; NOT stream SSE correctly. Bumping http-kit is a prerequisite for a real
        ;; migration (see FINDINGS.md).
        http-kit/http-kit {:mvn/version "2.9.0-beta3"}
        ring/ring-core {:mvn/version "1.13.0"}

        ;; Server-side hiccup -> HTML string rendering, on the JVM.
        no.cjohansen/replicant {:mvn/version "2025.12.1"}

        ;; Datastar: hypermedia over SSE.
        dev.data-star.clojure/sdk {:mvn/version "1.0.0-RC11"}
        dev.data-star.clojure/http-kit {:mvn/version "1.0.0-RC11"}

        ;; JSON for reading Datastar signals off requests.
        org.clojure/data.json {:mvn/version "2.5.1"}}}
